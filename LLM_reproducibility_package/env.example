# Environment variable template for the public reproducibility package
# Copy this file to a new file named .env and replace each placeholder with your own values.
# Do NOT commit the real .env file with active keys to a public repository.

OPENAI_API_KEY=PASTE_OPENAI_API_KEY_HERE
GEMINI_API_KEY=PASTE_GEMINI_API_KEY_HERE

# Azure OpenAI is used as the programmatic counterpart for the Copilot condition.
AZURE_OPENAI_API_KEY=PASTE_AZURE_OPENAI_API_KEY_HERE
AZURE_OPENAI_ENDPOINT=PASTE_AZURE_OPENAI_ENDPOINT_HERE
AZURE_OPENAI_DEPLOYMENT=PASTE_AZURE_OPENAI_DEPLOYMENT_NAME_HERE

PERPLEXITY_API_KEY=PASTE_PERPLEXITY_API_KEY_HERE

# Input and output folders
INPUT_ROOT=PASTE_ABSOLUTE_PATH_TO_01_QUESTION_SETS_HERE
OUTPUT_ROOT=PASTE_ABSOLUTE_PATH_TO_02_API_ANSWERS_HERE
